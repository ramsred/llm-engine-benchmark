# Optional bootstrap/runtime overrides. Copy to .env; bench loads simple KEY=VALUE lines.
# Do not use shell commands or substitutions in this file.
# HF_TOKEN is normally unnecessary for the public model and datasets.
# HF_TOKEN=hf_...
# PYTHON_BIN=python3
# BENCH_VENV_DIR=/path/to/.venv
# TOKENIZERS_PARALLELISM=false
